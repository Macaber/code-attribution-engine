{
  "name": "code-attribution-engine",
  "version": "1.0.0",
  "description": "AI code adoption rate attribution analysis engine",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && copyfiles -u 1 \"src/**/*.wasm\" dist/",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "ai",
    "code-attribution",
    "git-diff",
    "similarity"
  ],
  "license": "MIT",
