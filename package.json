    "bull": "^4.16.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "mysql2": "^3.22.0",
    "parse-diff": "^0.11.1",
    "tree-sitter-wasms": "^0.1.13",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@types/bull": "^3.15.9",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "copyfiles": "^2.4.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9"
  }
}
